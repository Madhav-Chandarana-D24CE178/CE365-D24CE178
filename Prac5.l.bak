%option noyywrap

%{
#include <stdio.h>
#include <string.h>

/* Counters */
int lineNumber = 1;
int symbolIndex = 0;
int tokenIndex = 0;
int errorIndex = 0;

/* Storage */
char symbolTable[100][50];
char tokenList[500][100];
char errorList[100][100];

/* Function declarations */
int isKeyword(char *);
int isSymbolPresent(char *);
void addSymbol(char *);
void addToken(char *);
void addError(char *);
%}

/* Definitions */
KEYWORD     int|float|char|double|long|short|void|return|if|else|while|for|do|break|continue|struct
ID          [a-zA-Z_][a-zA-Z0-9_]*
NUMBER      [0-9]+(\.[0-9]+)?
CHARCONST   \'[^\']\'
STRING      \"([^\\\"]|\\.)*\"
OPERATOR    \+|\-|\*|\/|=|==|!=|<=|>=|<|>|&&|\|\|
PUNCT       [\(\)\{\}\[\];,]

%%

"//".*                          ;
"/*"([^*]|\*+[^*/])*\*+"/"     ;

{KEYWORD}      {
                    char temp[100];
                    sprintf(temp, "Keyword: %s", yytext);
                    addToken(temp);
                }

{ID}           {
                    if (!isKeyword(yytext))
                    {
                        char temp[100];
                        sprintf(temp, "Identifier: %s", yytext);
                        addToken(temp);
                        addSymbol(yytext);
                    }
                }

{NUMBER}       {
                    char temp[100];
                    sprintf(temp, "Constant: %s", yytext);
                    addToken(temp);
                }

{CHARCONST}    {
                    char temp[100];
                    sprintf(temp, "Constant: %s", yytext);
                    addToken(temp);
                }

{STRING}       {
                    char temp[100];
                    sprintf(temp, "String: %s", yytext);
                    addToken(temp);
                }

{OPERATOR}     {
                    char temp[100];
                    sprintf(temp, "Operator: %s", yytext);
                    addToken(temp);
                }

{PUNCT}        {
                    char temp[100];
                    sprintf(temp, "Punctuation: %s", yytext);
                    addToken(temp);
                }

[0-9]+[a-zA-Z]+ {
                    char temp[100];
                    sprintf(temp, "Line %d : %s invalid lexeme",
                            lineNumber, yytext);
                    addError(temp);
                }

\n             { lineNumber++; }
[ \t]+         ;

.              {
                    char temp[100];
                    sprintf(temp, "Line %d : %s invalid lexeme",
                            lineNumber, yytext);
                    addError(temp);
                }

%%

/* ---------- Helper Functions ---------- */

int isKeyword(char *word)
{
    int i;
    const char *keywords[] = {
        "int","float","char","double","long","short","void","return",
        "if","else","while","for","do","break","continue","struct"
    };

    for (i = 0; i < 14; i++)
        if (strcmp(word, keywords[i]) == 0)
            return 1;
    return 0;
}

int isSymbolPresent(char *symbol)
{
    int i;
    for (i = 0; i < symbolIndex; i++)
        if (strcmp(symbolTable[i], symbol) == 0)
            return 1;
    return 0;
}

void addSymbol(char *symbol)
{
    if (!isSymbolPresent(symbol))
    {
        strcpy(symbolTable[symbolIndex], symbol);
        symbolIndex++;
    }
}

void addToken(char *token)
{
    strcpy(tokenList[tokenIndex], token);
    tokenIndex++;
}

void addError(char *error)
{
    strcpy(errorList[errorIndex], error);
    errorIndex++;
}

/* ---------- MAIN ---------- */

int main()
{
    int i;

    printf("Enter C Program (Press CTRL+Z then Enter to finish):\n\n");
    yylex();

    printf("\n\nTOKENS:\n\n");
    for (i = 0; i < tokenIndex; i++)
        printf("%s\n", tokenList[i]);

    printf("\nLEXICAL ERRORS:\n");
    for (i = 0; i < errorIndex; i++)
        printf("%s\n", errorList[i]);

    printf("\nSYMBOL TABLE ENTRIES:\n");
    for (i = 0; i < symbolIndex; i++)
        printf("%d) %s\n", i + 1, symbolTable[i]);

    return 0;
}
