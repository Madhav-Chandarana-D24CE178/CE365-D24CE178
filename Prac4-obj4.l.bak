%option noyywrap

%{
#include <stdio.h>

int lowerCount = 0;
int upperCount = 0;
int digitCount = 0;
int symbolCount = 0;
int totalLength = 0;
%}

%%
[a-z]      { lowerCount++; totalLength++; }
[A-Z]      { upperCount++; totalLength++; }
[0-9]      { digitCount++; totalLength++; }
[*;#$@]    { symbolCount++; totalLength++; }
[ \t]      { }
\n         { return 0; }
.          { totalLength++; }
%%

int main()
{
    printf("Enter password: ");
    yylex();

    if (totalLength >= 9 && totalLength <= 15 &&
        lowerCount >= 1 &&
        upperCount >= 1 &&
        digitCount >= 1 &&
        symbolCount >= 1)
    {
        printf("\nValid password\n");
    }
    else
    {
        printf("\nInvalid password\n");
    }

    getchar();   /* <-- THIS LINE STOPS CONSOLE FROM CLOSING */
    return 0;
}
